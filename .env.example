# Core database connection
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ai_sales_bot

# Optional schema mapping YAML path
SCHEMA_MAPPING_PATH=config/schema_mapping.example.yaml

# Analytics behavior
DEFAULT_TIMEZONE=Europe/Moscow
REPORTS_DIR=./reports
LOOKBACK_DAYS=30
LOST_LEAD_INACTIVITY_HOURS=48
LOW_CONFIDENCE_THRESHOLD=0.55
STUCK_STAGE_DAYS=3

# Report delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SEND_TELEGRAM_REPORT=false

# LLM insights (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ENABLE_LLM_INSIGHTS=false

# Scheduler
DAILY_REPORT_CRON=0 20 * * *

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
